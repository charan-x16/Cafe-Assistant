APP_NAME=Cafe Assistant
ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://cafe:cafe@localhost:5432/cafe_assistant
REDIS_URL=redis://localhost:6379/0
# SQL source of truth. Use Neon here when running without local Docker Postgres.
# Neon format for this async app:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require
# Local embedding provider. First BGE run may download the model from Hugging Face.
EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
# Vector index. Qdrant returns candidate ids; Postgres/Neon remains source of truth.
VECTOR_PROVIDER=qdrant
QDRANT_URL=
QDRANT_ENDPOINT=
QDRANT_API_KEY=
QDRANT_COLLECTION=cafe_assistant_menu_policy
QDRANT_TIMEOUT_SECONDS=3.0
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
# Chat providers remain local for no-network development. Set either value to llm
# to route through LLM_PROVIDER/LLM_MODEL with gateway retries and fallback.
CHEAP_CHAT_PROVIDER=local
STRONG_CHAT_PROVIDER=local
CHAT_TIMEOUT_SECONDS=8.0
CHAT_RETRIES=1
AGENT_DEADLINE_SECONDS=60.0
AGENT_MAX_TOOL_CALLS=4
IDENTITY_DEVICE_TOKEN_HASH_SECRET=replace-this-in-nonlocal-envs
DEVICE_TOKEN_BYTES=32
DEVICE_TOKEN_TTL_SECONDS=7776000
RATE_LIMIT_SESSION_REQUESTS=60
RATE_LIMIT_SESSION_WINDOW_SECONDS=60
RATE_LIMIT_IP_REQUESTS=120
RATE_LIMIT_IP_WINDOW_SECONDS=60
RATE_LIMIT_HASH_SECRET=replace-this-in-nonlocal-envs
PROFILE_RETENTION_DAYS=365
SESSION_RETENTION_DAYS=14
AUDIT_RETENTION_DAYS=730
OBSERVABILITY_ADMIN_TOKEN=replace-this-in-nonlocal-envs
OBSERVABILITY_TRACE_STORE_PATH=var/observability/traces.jsonl
TRACE_STORE_MAX_TRACES=500
METRICS_LATENCY_SAMPLE_LIMIT=2000
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
DEFAULT_CHAT_MODEL_NAME=gpt-4o-mini
CHEAP_MODEL_INPUT_COST_PER_1K=0
CHEAP_MODEL_OUTPUT_COST_PER_1K=0
STRONG_MODEL_INPUT_COST_PER_1K=0
STRONG_MODEL_OUTPUT_COST_PER_1K=0
LATENCY_BUDGET_MS=1500
